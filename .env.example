# இந்த file-ஐ .env.local என copy செய்து values மட்டும் நிரப்பவும்.
GEMINI_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional overrides
DATABASE_PATH=./data/review-studio.sqlite
MEDIA_ROOT=./media
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# Local Piper Tamil TTS (API செலவு இல்லை)
PIPER_EXECUTABLE_PATH=./.venv-local-tts/Scripts/piper.exe
PIPER_MODEL_PATH=./models/piper/ta_IN-rasa_female-medium.onnx

# YouTube upload (OAuth client from Google Cloud Console)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_TOKEN_PATH=./data/youtube-oauth.json
